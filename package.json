{
  "name": "@e-watson/axon",
  "version": "0.0.1",
  "description": "Minimal HTTP pipeline framework for Node.js",
  "keywords": [
    "node",
    "http",
    "middleware",
    "router",
    "framework"
  ],
  "homepage": "https://github.com/e-Watson-dot-ua/axon#readme",
  "bugs": { "url": "https://github.com/e-Watson-dot-ua/axon/issues" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e-Watson-dot-ua/axon.git"
  },
  "license": "MIT",
  "author": {
    "name": "e-Watson",
    "url": "https://github.com/e-Watson-dot-ua"
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": { ".": "./src/index.js" },
  "files": [ "src" ],
  "sideEffects": false,
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test \"tests/**/*.test.js\"",
    "prepublishOnly": "npm run lint && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": ">=18.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0"
  }
}
